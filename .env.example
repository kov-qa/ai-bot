# Telegram
TELEGRAM_BOT_TOKEN=put-your-token-here

# Provider: gemini | xai
MODEL_PROVIDER=gemini

# API keys (заполни нужный)
GEMINI_API_KEY=
XAI_API_KEY=

# Models (опционально)
GEMINI_MODEL=gemini-3-flash-preview
XAI_MODEL=grok-4-latest

# Generation
AI_TEMPERATURE=0.7

# Доступ (через запятую). Пусто = всем разрешено.
TELEGRAM_ADMIN_IDS=
ALLOWED_CHAT_IDS=

# Rate limit: минимальный интервал между запросами одного пользователя, сек
USER_COOLDOWN_SECONDS=2
